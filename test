-- Unnamed Enhancements - Fixed & Stable (2026)
print("🔧 Loading Unnamed Enhancements...")

local success, Library = pcall(function()
    return loadstring(game:HttpGet("https://raw.githubusercontent.com/violin-suzutsuki/LinoriaLib/main/Library.lua"))()
end)

if not success or not Library then
    print("❌ LinoriaLib failed to load. Check your internet connection or the URL.")
    return
end

local Window = Library:CreateWindow({
    Title = "Unnamed Enhancements - Fixed Edition",
    Center = true,
    AutoShow = true,
    TabPadding = 8
})

local Tabs = {
    Combat = Window:AddTab("Combat"),
    Visuals = Window:AddTab("Visuals"),
    Movement = Window:AddTab("Movement"),
    Misc = Window:AddTab("Misc")
}

-- ==================== SERVICES & VARS ====================
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Mouse = LocalPlayer:GetMouse()

local silentAim, ragebot, triggerbot = false, false, false
local fov, aimPart, prediction = 150, "Head", 0.12
local espEnabled, tracersEnabled, fovCircleEnabled = false, false, false
local flyEnabled, flySpeed, speedHack, walkSpeed = false, 60, false, 50

-- ==================== UI SETUP ====================
local CombatTab = Tabs.Combat
local AimGroup = CombatTab:AddLeftGroupbox("Aim Assist")

AimGroup:AddToggle("SilentAim", {Text = "Silent Aim", Default = false}):OnChanged(function() silentAim = Toggles.SilentAim.Value end)
AimGroup:AddToggle("Ragebot", {Text = "Ragebot (Auto Fire)", Default = false}):OnChanged(function() ragebot = Toggles.Ragebot.Value end)

-- Fixed Slider Logic to prevent 'Rounding' errors
AimGroup:AddSlider("FOV", {Text = "Aim FOV", Default = 150, Min = 10, Max = 800, Rounding = 0, Compact = false}):OnChanged(function() fov = Options.FOV.Value end)
AimGroup:AddDropdown("AimPart", {Text = "Aim Part", Values = {"Head", "UpperTorso", "HumanoidRootPart"}, Default = "Head"}):OnChanged(function() aimPart = Options.AimPart.Value end)
AimGroup:AddSlider("Prediction", {Text = "Prediction", Default = 0.12, Min = 0, Max = 0.5, Rounding = 2, Compact = false}):OnChanged(function() prediction = Options.Prediction.Value end)

local VisualsTab = Tabs.Visuals
local EspGroup = VisualsTab:AddLeftGroupbox("ESP")
EspGroup:AddToggle("ESP", {Text = "Full ESP", Default = false}):OnChanged(function() espEnabled = Toggles.ESP.Value end)
EspGroup:AddToggle("Tracers", {Text = "Tracers", Default = false}):OnChanged(function() tracersEnabled = Toggles.Tracers.Value end)
EspGroup:AddToggle("FOVCircle", {Text = "FOV Circle", Default = false}):OnChanged(function() fovCircleEnabled = Toggles.FOVCircle.Value end)

local MoveTab = Tabs.Movement
local MoveGroup = MoveTab:AddLeftGroupbox("Movement")
MoveGroup:AddToggle("Fly", {Text = "Fly", Default = false}):OnChanged(function() flyEnabled = Toggles.Fly.Value end)
MoveGroup:AddSlider("FlySpeed", {Text = "Fly Speed", Default = 60, Min = 10, Max = 300, Rounding = 0}):OnChanged(function() flySpeed = Options.FlySpeed.Value end)
MoveGroup:AddToggle("SpeedHack", {Text = "Speed Hack", Default = false}):OnChanged(function() speedHack = Toggles.SpeedHack.Value end)
MoveGroup:AddSlider("WalkSpeed", {Text = "WalkSpeed", Default = 50, Min = 16, Max = 250, Rounding = 0}):OnChanged(function() walkSpeed = Options.WalkSpeed.Value end)

-- ==================== CORE LOGIC ====================
-- Pre-create FOV Circle to avoid "Visible" property errors in loops
local fovCircle = Drawing.new("Circle")
fovCircle.Visible = false
fovCircle.Thickness = 2
fovCircle.Color = Color3.fromRGB(255, 0, 0)
fovCircle.NumSides = 64

RunService.RenderStepped:Connect(function()
    if fovCircleEnabled then
        fovCircle.Visible = true
        fovCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        fovCircle.Radius = fov
    else
        fovCircle.Visible = false
    end
end)

-- FIXED TOGGLE KEY
-- This uses SetOpen instead of Window:Toggle() to prevent the "number with Visible" crash
UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.Insert or input.KeyCode == Enum.KeyCode.RightShift then
        Library:SetOpen(not Library.Opened)
    end
end)

Library:Notify("Unnamed Enhancements Fixed! Press Insert to toggle.")
print("✅ Script logic and UI errors resolved.")
