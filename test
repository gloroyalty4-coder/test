-- ==================== REAL CHAMS ====================
local function createChams(character)
    if highlights[character] then return end
    local highlight = Instance.new("Highlight")
    highlight.FillColor = chamsFillColor
    highlight.OutlineColor = chamsOutlineColor
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.Adornee = character
    highlight.Parent = character
    highlights[character] = highlight
end

RunService.RenderStepped:Connect(function()
    if not chamsEnabled then return end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            createChams(player.Character)
        end
    end
end)

-- ==================== FULL ESP + TRACERS ====================
local function createESP(plr)
    if espDrawings[plr] then return end
    espDrawings[plr] = {
        box = Drawing.new("Square"),
        name = Drawing.new("Text"),
        healthBar = Drawing.new("Square"),
        distance = Drawing.new("Text")
    }
    local d = espDrawings[plr]
    d.box.Thickness = 2
    d.box.Color = Color3.new(1,0,0)
    d.box.Transparency = 1
    d.box.Filled = false

    d.name.Size = 14
    d.name.Center = true
    d.name.Outline = true
    d.name.Color = Color3.new(1,1,1)

    d.healthBar.Color = Color3.new(0,1,0)
    d.healthBar.Thickness = 1
    d.healthBar.Filled = true

    d.distance.Size = 13
    d.distance.Center = true
    d.distance.Outline = true
    d.distance.Color = Color3.new(1,1,1)
end

RunService.RenderStepped:Connect(function()
    if not espEnabled then
        for _, drawings in pairs(espDrawings) do
            drawings.box.Visible = false
            drawings.name.Visible = false
            drawings.healthBar.Visible = false
            drawings.distance.Visible = false
        end
        return
    end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr.Character:FindFirstChild("Head") and plr.Character:FindFirstChild("Humanoid") then
            local root = plr.Character.HumanoidRootPart
            local head = plr.Character.Head
            local humanoid = plr.Character.Humanoid

            local rootPos, onScreen = Camera:WorldToViewportPoint(root.Position)
            if onScreen then
                createESP(plr)
                local d = espDrawings[plr]

                local top = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 2.5, 0))
                local bottom = Camera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
                local height = bottom.Y - top.Y
                local width = height * 0.6

                -- Box
                d.box.Size = Vector2.new(width, height)
                d.box.Position = Vector2.new(rootPos.X - width/2, top.Y)
                d.box.Visible = true

                -- Name
                d.name.Text = plr.Name
                d.name.Position = Vector2.new(rootPos.X, top.Y - 18)
                d.name.Visible = true

                -- Health Bar
                local healthPercent = humanoid.Health / humanoid.MaxHealth
                d.healthBar.Size = Vector2.new(4, height * healthPercent)
                d.healthBar.Position = Vector2.new(rootPos.X - width/2 - 8, top.Y + height * (1 - healthPercent))
                d.healthBar.Visible = true

                -- Distance
                local dist = math.floor((root.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude)
                d.distance.Text = dist .. " studs"
                d.distance.Position = Vector2.new(rootPos.X, bottom.Y + 5)
                d.distance.Visible = true

                -- Tracers
                if tracersEnabled then
                    if not tracers[plr] then
                        tracers[plr] = Drawing.new("Line")
                        tracers[plr].Thickness = 1
                        tracers[plr].Color = Color3.new(1,0,0)
                        tracers[plr].Transparency = 0.7
                    end
                    local tracer = tracers[plr]
                    tracer.From = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y)
                    tracer.To = Vector2.new(rootPos.X, rootPos.Y)
                    tracer.Visible = true
                end
            end
        end
    end

    -- Clean tracers
    if not tracersEnabled then
        for _, t in pairs(tracers) do t.Visible = false end
    end
end)

-- ==================== RAGEBOT + AUTO FIRE ====================
local function getNearestEnemy()
    local closest, shortest = nil, math.huge
    local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild(aimPart) then
            local dist = (plr.Character[aimPart].Position - myRoot.Position).Magnitude
            if dist < shortest and dist < 300 then
                shortest = dist
                closest = plr.Character[aimPart]
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    if not ragebot then return end
    local target = getNearestEnemy()
    if not target or not LocalPlayer.Character then return end

    local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
    if tool then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        hrp.CFrame = CFrame.lookAt(hrp.Position, target.Position)
        mouse1click()
    end
end)

-- ==================== SILENT AIM + WALLBANG + ANTI-KATANA ====================
local oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()

    if (silentAim or ragebot) and (method == "FireServer" or method == "InvokeServer") then
        local name = self.Name:lower()
        if name:find("bullet") or name:find("shoot") or name:find("hit") or name:find("damage") then
            local target = getNearestEnemy()
            if target then
                local pos = target.Position + (target.Velocity * prediction)
                args[1] = wallbang and pos or pos
            end
        end
    end

    if antiKatana and (method == "FireServer" or method == "InvokeServer") then
        local name = self.Name:lower()
        if name:find("stab") or name:find("katana") or name:find("knife") or name:find("damage") then
            return
        end
    end

    return oldNamecall(self, unpack(args))
end)

-- ==================== MOVEMENT & OTHER FEATURES ====================
-- Fly
local bodyVelocity
RunService.RenderStepped:Connect(function()
    if flyEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        if not bodyVelocity then
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
            bodyVelocity.Parent = hrp
        end
        local cam = workspace.CurrentCamera
        local moveDir = Vector3.new()
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir -= Vector3.new(0,1,0) end

        bodyVelocity.Velocity = (moveDir.Unit or Vector3.new()) * flySpeed
    elseif bodyVelocity then
        bodyVelocity:Destroy()
        bodyVelocity = nil
    end
end)

