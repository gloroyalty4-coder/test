-- AGGRESSIVE MODULE FINDER
-- ═══════════════════════════════════════════════
local CosmeticLibrary, ItemLibrary, ReplicatedClass, ClientViewModel = nil, nil, nil, nil

task.spawn(function()
    task.wait(3)
    Status.Text = "Scanning memory for modules..."

    -- Method 1: Deep descendant search
    local Modules = ReplicatedStorage:FindFirstChild("Modules") or ReplicatedStorage
    for _, v in ipairs(Modules:GetDescendants()) do
        if v.Name == "CosmeticLibrary" and not CosmeticLibrary then
            local s, r = pcall(require, v)
            if s and r then CosmeticLibrary = r end
        end
        if v.Name == "ItemLibrary" and not ItemLibrary then
            local s, r = pcall(require, v)
            if s and r then ItemLibrary = r end
        end
        if v.Name == "ReplicatedClass" and not ReplicatedClass then
            local s, r = pcall(require, v)
            if s and r then ReplicatedClass = r end
        end
    end

    -- Method 2: ClientViewModel search
    local ps = player.PlayerScripts:FindFirstChild("Modules")
    if ps then
        for _, v in ipairs(ps:GetDescendants()) do
            if v.Name == "ClientViewModel" and not ClientViewModel then
                local s, r = pcall(require, v)
                if s and r then ClientViewModel = r end
            end
        end
    end

    -- Method 3: getgc + upvalue scan (most powerful for restricted executors)
    if not CosmeticLibrary or not ClientViewModel then
        for _, obj in ipairs(getgc(true)) do
            if typeof(obj) == "table" then
                if not CosmeticLibrary and (obj.Cosmetics or obj.Equip) then CosmeticLibrary = obj end
                if not ItemLibrary and obj.ViewModels then ItemLibrary = obj end
                if not ClientViewModel and (obj.new and obj.GetWrap) then ClientViewModel = obj end
                if not ReplicatedClass and typeof(obj.ToEnum) == "function" then ReplicatedClass = obj end
            end
        end
    end

    if not CosmeticLibrary or not ReplicatedClass or not ClientViewModel then
        Status.Text = "❌ Failed to find modules"
        warn("Module status:", {CosmeticLibrary = not not CosmeticLibrary, ReplicatedClass = not not ReplicatedClass, ClientViewModel = not not ClientViewModel})
        return
    end

    Status.Text = "✅ Modules found! Applying hooks..."

    -- getCosmeticData
    local function getCosmeticData(name, cType)
        local base = CosmeticLibrary.Cosmetics and CosmeticLibrary.Cosmetics[name]
        if not base then return nil end
        local data = table.clone(base)
        data.Name = name
        data.Type = cType
        return data
    end

    -- Hooks
    local oldGetWrap = ClientViewModel.GetWrap
    ClientViewModel.GetWrap = function(self)
        local ok, res = pcall(function()
            local w = self.ClientItem and self.ClientItem.Name
            if w and _G.EquippedData[w] then
                local wrap = _G.EquippedData[w].Wrap
                if wrap and wrap ~= "None" then return getCosmeticData(wrap, "Wrap") end
            end
        end)
        if ok and res then return res end
        return oldGetWrap(self)
    end

    local oldNew = ClientViewModel.new
    ClientViewModel.new = function(data, item)
        pcall(function()
            if not item or not item.Name then return end
            local skin = _G.EquippedData[item.Name] and _G.EquippedData[item.Name].Skin
            if not skin or skin == "Default" then return end
            local cos = getCosmeticData(skin, "Skin")
            if not cos then return end
            local dk = ReplicatedClass:ToEnum("Data")
            local sk = ReplicatedClass:ToEnum("Skin")
            local nk = ReplicatedClass:ToEnum("Name")
            data[dk] = data[dk] or {}
            data[dk][sk] = cos
            data[dk][nk] = skin
        end)
        local vm = oldNew(data, item)
        task.delay(0.1, function() pcall(function() if vm._UpdateWrap then vm:_UpdateWrap() end end) end)
        return vm
    end

    local function ApplyAllSkins()
        for w, info in pairs(_G.EquippedData) do
            if info.Skin ~= "Default" then
                pcall(function() CosmeticLibrary.Equip(w, "Skin", info.Skin) end)
            end
        end
    end

    -- Remaining GUI functions (MakeWeaponBtn, GetThumb, EquipSkin, etc.)
    local function GetThumb(name)
        if ItemLibrary and ItemLibrary.ViewModels and ItemLibrary.ViewModels[name] then
            local d = ItemLibrary.ViewModels[name]
            return d.ImageHighResolution or d.Image or d.Thumbnail or ""
        end
        return ""
    end

    local function EquipSkin(weapon, skin)
        _G.EquippedData[weapon].Skin = skin
        pcall(function() CosmeticLibrary.Equip(weapon, "Skin", skin) end)
        SelectedLabel.Text = "✅ EQUIPPED: " .. weapon .. " — " .. skin
    end

    local function MakeWeaponBtn(weapon)
        -- (Same as previous full version - I kept it short here for space, but use the full MakeWeaponBtn from my earlier message)
        local btn = Instance.new("TextButton", WeaponScroll)
        btn.Size = UDim2.new(1, -10, 0, 52)
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 48)
        btn.Text = "   " .. weapon
        btn.TextColor3 = Color3.new(1,1,1)
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.Font = Enum.Font.GothamSemibold
        btn.TextSize = 16

        -- Add image and badge (copy from previous full code)
        -- ... (the full button code with click handler)
    end

    for weapon in pairs(SkinLists) do MakeWeaponBtn(weapon) end

    ApplyAllSkins()

    Status.Text = "✅ Loaded Successfully! Press K"
    print("[+] Aniha Skin Changer is now ready!")
end)
