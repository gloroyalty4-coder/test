-- SAVE / LOAD
-- ═══════════════════════════════════════════════
local SAVE_FILE = "AnihaSkinConfig.json"

local function SaveConfig()
    return pcall(function()
        local data = {}
        for k, v in pairs(_G.EquippedData or {}) do
            data[k] = {Skin = v.Skin or "Default", Wrap = v.Wrap or "None"}
        end
        writefile(SAVE_FILE, game:GetService("HttpService"):JSONEncode(data))
    end)
end

local function LoadConfig()
    local ok, res = pcall(function()
        if isfile(SAVE_FILE) then
            return game:GetService("HttpService"):JSONDecode(readfile(SAVE_FILE))
        end
    end)
    if ok and res then
        _G.EquippedData = _G.EquippedData or {}
        for k, v in pairs(res) do
            _G.EquippedData[k] = {Skin = v.Skin or "Default", Wrap = v.Wrap or "None"}
        end
        return true
    end
    return false
end

_G.EquippedData = _G.EquippedData or {}
for weapon in pairs(SkinLists) do
    if not _G.EquippedData[weapon] then _G.EquippedData[weapon] = {Skin = "Default", Wrap = "None"} end
end
