-- IMPROVED ROBUST REQUIRE (for ANY executor)
-- ═══════════════════════════════════════════════
local function robust_require(module)
    local mName = tostring(module):gsub("^.+%.", "") -- cleaner name

    -- Tier 1: Global cache
    if shared[mName] or _G[mName] then
        _G.Telemetry[mName] = "Global Cache"
        return shared[mName] or _G[mName]
    end
    if getrenv then
        local renv = getrenv()
        if renv._G[mName] or renv.shared[mName] then
            _G.Telemetry[mName] = "getrenv Cache"
            return renv._G[mName] or renv.shared[mName]
        end
    end

    -- Tier 2: Identity + require with multiple fallbacks
    local setidentity = setthreadidentity or set_thread_identity or (syn and syn.set_thread_identity) or (fluxus and fluxus.set_thread_identity) or getgenv and getgenv().set_thread_identity
    local getidentity = getthreadidentity or get_thread_identity or (syn and syn.get_thread_identity) or (fluxus and fluxus.get_thread_identity) or getgenv and getgenv().get_thread_identity

    local old_identity
    if getidentity and setidentity then
        pcall(function() old_identity = getidentity() end)
        pcall(function() setidentity(2) end)
    end

    local success, result = pcall(require, module)

    -- Extra require attempts (common on some executors)
    if not success then
        if getgenv and getgenv().require then
            success, result = pcall(getgenv().require, module)
        end
    end
    if not success then
        success, result = pcall(function() return require(module) end) -- retry
    end

    -- Restore identity
    if setidentity and old_identity then
        pcall(function() setidentity(old_identity) end)
    end

    if success and result then
        _G.Telemetry[mName] = "Require Success (ID " .. (getidentity and getidentity() or "?") .. ")"
        return result
    end

    -- Tier 3: Memory scan (getgc + getreg + upvalues)
    local scan_funcs = {getgc, getregistry, debug.getregistry}
    local getupvalues = debug.getupvalues or getupvalues or getupvalue

    for _, scan in ipairs(scan_funcs) do
        if typeof(scan) == "function" then
            local ok, objs = pcall(scan, true)
            if ok and typeof(objs) == "table" then
                for _, v in pairs(objs) do
                    if typeof(v) == "table" then
                        if mName:find("CosmeticLibrary") and (v.Cosmetics or v.Equip) then
                            _G.Telemetry[mName] = "GC Scan - CosmeticLibrary"
                            return v
                        end
                        if mName:find("ItemLibrary") and v.ViewModels then
                            _G.Telemetry[mName] = "GC Scan - ItemLibrary"
                            return v
                        end
                        if mName:find("ClientViewModel") and (v.new or v.GetWrap) then
                            _G.Telemetry[mName] = "GC Scan - ClientViewModel"
                            return v
                        end
                        if mName:find("ReplicatedClass") and typeof(v.ToEnum) == "function" then
                            _G.Telemetry[mName] = "GC Scan - ReplicatedClass"
                            return v
                        end
                    end
                end
            end
        end
    end

    -- Upvalue scan as last resort
    if getupvalues then
        for _, f in pairs(getgc(false)) do
            if typeof(f) == "function" then
                local ups = getupvalues(f)
                for _, up in pairs(ups) do
                    if typeof(up) == "table" then
                        if mName:find("CosmeticLibrary") and up.Cosmetics and up.Equip then
                            _G.Telemetry[mName] = "Upvalue Scan"
                            return up
                        end
                        if mName:find("ItemLibrary") and up.ViewModels then
                            _G.Telemetry[mName] = "Upvalue Scan"
                            return up
                        end
                    end
                end
            end
        end
    end

    _G.Telemetry[mName] = "NOT_FOUND"
    warn("[!] Aniha: Failed to find module -> " .. mName .. " | Executor may have heavy restrictions.")
    return nil
end

