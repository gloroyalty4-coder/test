-- Simple Music Player (Client-sided - you will hear it clearly)
local Players = game:GetService("Players")
local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local screenGui = Instance.new("ScreenGui")
screenGui.Name = "MusicPlayer"
screenGui.ResetOnSpawn = false
screenGui.Parent = playerGui

local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 300, 0, 180)
frame.Position = UDim2.new(0.5, -150, 0.5, -90)
frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
frame.BorderSizePixel = 0
frame.Parent = screenGui

local title = Instance.new("TextLabel")
title.Size = UDim2.new(1, 0, 0, 30)
title.BackgroundTransparency = 1
title.Text = "🎵 Music Player"
title.TextColor3 = Color3.new(1,1,1)
title.TextScaled = true
title.Parent = frame

local idBox = Instance.new("TextBox")
idBox.Size = UDim2.new(0.9, 0, 0, 30)
idBox.Position = UDim2.new(0.05, 0, 0, 40)
idBox.PlaceholderText = "Paste Audio ID here"
idBox.Text = ""
idBox.TextScaled = true
idBox.Parent = frame

local playBtn = Instance.new("TextButton")
playBtn.Size = UDim2.new(0.4, 0, 0, 40)
playBtn.Position = UDim2.new(0.05, 0, 0, 80)
playBtn.Text = "▶ Play"
playBtn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
playBtn.TextColor3 = Color3.new(1,1,1)
playBtn.TextScaled = true
playBtn.Parent = frame

local stopBtn = Instance.new("TextButton")
stopBtn.Size = UDim2.new(0.4, 0, 0, 40)
stopBtn.Position = UDim2.new(0.55, 0, 0, 80)
stopBtn.Text = "■ Stop"
stopBtn.BackgroundColor3 = Color3.fromRGB(170, 0, 0)
stopBtn.TextColor3 = Color3.new(1,1,1)
stopBtn.TextScaled = true
stopBtn.Parent = frame

local status = Instance.new("TextLabel")
status.Size = UDim2.new(0.9, 0, 0, 30)
status.Position = UDim2.new(0.05, 0, 0, 130)
status.BackgroundTransparency = 1
status.Text = "Ready"
status.TextColor3 = Color3.new(1,1,1)
status.TextScaled = true
status.Parent = frame

-- Sound object (parented to workspace so it's 3D audio)
local sound = Instance.new("Sound")
sound.Name = "GlobalMusic"
sound.Volume = 0.7
sound.Looped = false
sound.Parent = workspace

local currentSound = nil

playBtn.MouseButton1Click:Connect(function()
    local id = tonumber(idBox.Text)
    if not id then
        status.Text = "Invalid ID!"
        return
    end
    
    if currentSound then currentSound:Stop() end
    
    sound.SoundId = "rbxassetid://" .. id
    sound:Play()
    currentSound = sound
    status.Text = "Playing ID: " .. id
end)

stopBtn.MouseButton1Click:Connect(function()
    if currentSound then
        currentSound:Stop()
        status.Text = "Stopped"
    end
end)

print("Music Player loaded! Paste an audio ID and click Play.")
