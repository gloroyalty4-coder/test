-- Simple Universal Animation Loader (like Klue Animations style)
-- You can add your own GUI, animation list, or emotes here

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))() -- optional GUI lib
local Window = Library.CreateLib("My Animation Hub", "DarkTheme")

local Tab = Window:NewTab("Animations")
local Section = Tab:NewSection("Play Animations")

Section:NewButton("Dance 1", "Plays a cool dance", function()
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://YOUR_ANIMATION_ID_HERE"
    local track = game.Players.LocalPlayer.Character.Humanoid:LoadAnimation(anim)
    track:Play()
end)

