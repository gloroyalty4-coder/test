local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Riel Hub | Rivals Edition",
   LoadingTitle = "Loading Skin Modules...",
   LoadingSubtitle = "Developed by 6sixig",
   ConfigurationSaving = { Enabled = true, FileName = "RielRivals" },
   Theme = "BloodTheme" 
})

-- Skin Database: Add the Texture IDs for the skins here
local skinIDs = {
    ["Default"] = "",
    ["Gold"]    = "rbxassetid://10878141290",
    ["Diamond"] = "rbxassetid://10878142721",
    ["Pixel"]   = "rbxassetid://10878144052",
    ["Galaxy"]  = "rbxassetid://10878145563",
    ["Void"]    = "rbxassetid://10878147102",
    ["Ruby"]    = "rbxassetid://10878148550"
}

-- Table to store your current choices
local userSelections = {}

-- Function to apply the texture to the weapon parts
local function applySkin(tool)
    local skinID = userSelections[tool.Name]
    if skinID and skinID ~= "" then
        for _, part in pairs(tool:GetDescendants()) do
            if part:IsA("MeshPart") then
                part.TextureID = skinID
            elseif part:IsA("Texture") or part:IsA("Decal") then
                part.Texture = skinID
            end
        end
    end
end

-- Monitor character for weapon equipping
local player = game.Players.LocalPlayer
player.CharacterAdded:Connect(function(char)
    char.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then
            task.wait(0.1) -- Small delay to ensure tool is fully loaded
            applySkin(child)
        end
    end)
end)

-- Main Tab
local SkinTab = Window:CreateTab("Skin Changer", 4483362458)

SkinTab:CreateSection("Weapon Selection")

-- List of weapons in Rivals
local weapons = {
    "Assault Rifle", "Sniper", "Shotgun", "Knife", 
    "Deagle", "RPG", "MP5", "Flamethrower", "Railgun"
}

-- Create a dropdown for every weapon automatically
for _, weaponName in pairs(weapons) do
    SkinTab:CreateDropdown({
        Name = weaponName,
        Options = {"Default", "Gold", "Diamond", "Pixel", "Galaxy", "Void", "Ruby"},
        CurrentOption = {"Default"},
        MultipleOptions = false,
        Callback = function(Option)
            local selection = Option[1]
            userSelections[weaponName] = skinIDs[selection]
            
            -- If currently holding the weapon, update it instantly
            local character = player.Character
            if character and character:FindFirstChild(weaponName) then
                applySkin(character[weaponName])
            end
        end,
    })
end

SkinTab:CreateSection("Extras")

SkinTab:CreateButton({
   Name = "Force Update Current Weapon",
   Callback = function()
       local char = player.Character
       if char then
           for _, tool in pairs(char:GetChildren()) do
               if tool:IsA("Tool") then
                   applySkin(tool)
               end
           end
       end
   end,
})

Rayfield:Notify({
   Title = "Riel Hub Loaded",
   Content = "Select your skins and equip the weapon to apply.",
   Duration = 6.5,
   Image = 4483362458,
})
