-- Stability Check: Ensure Rayfield loads correctly
local success, Rayfield = pcall(function()
    return loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
end)

if not success or not Rayfield then 
    warn("Riel Hub: Failed to load Rayfield Library.") 
    return 
end

local Window = Rayfield:CreateWindow({
   Name = "Riel Hub | Rivals Edition",
   LoadingTitle = "Loading Skin Modules...",
   LoadingSubtitle = "by 6sixig",
   ConfigurationSaving = { Enabled = false }, -- Set to false to prevent 'no theme on file' errors
   Theme = "BloodTheme" 
})

-- Skin Database
local skinIDs = {
    ["Default"] = "",
    ["Gold"]    = "rbxassetid://10878141290",
    ["Diamond"] = "rbxassetid://10878142721",
    ["Pixel"]   = "rbxassetid://10878144052",
    ["Galaxy"]  = "rbxassetid://10878145563",
    ["Void"]    = "rbxassetid://10878147102",
    ["Ruby"]    = "rbxassetid://10878148550"
}

local userSelections = {}
local player = game:GetService("Players").LocalPlayer

-- Improved Skin Applier with Nil Checks
local function applySkin(tool)
    if not tool or not tool:IsA("Tool") then return end
    
    local skinID = userSelections[tool.Name]
    if skinID and skinID ~= "" then
        for _, part in pairs(tool:GetDescendants()) do
            -- Check for both MeshParts and standard Parts with Textures
            if part:IsA("MeshPart") then
                part.TextureID = skinID
            elseif part:IsA("Texture") or part:IsA("Decal") then
                part.Texture = skinID
            end
        end
    end
end

-- Listener for Equipping Weapons
player.CharacterAdded:Connect(function(char)
    char.ChildAdded:Connect(function(child)
        task.wait(0.2) -- Wait for tool models to load properly
        applySkin(child)
    end)
end)

local SkinTab = Window:CreateTab("Skin Changer", 4483362458)
SkinTab:CreateSection("Weapon Selection")

-- Every Weapon in Rivals
local weapons = {
    "Assault Rifle", "Sniper", "Shotgun", "Knife", 
    "Deagle", "RPG", "MP5", "Flamethrower", "Railgun",
    "Minigun", "Bow", "Katana", "Grenade Launcher"
}

for _, weaponName in pairs(weapons) do
    SkinTab:CreateDropdown({
        Name = weaponName,
        Options = {"Default", "Gold", "Diamond", "Pixel", "Galaxy", "Void", "Ruby"},
        CurrentOption = {"Default"},
        MultipleOptions = false,
        Callback = function(Option)
            userSelections[weaponName] = skinIDs[Option[1]]
            
            -- Live update if holding weapon
            if player.Character then
                local tool = player.Character:FindFirstChild(weaponName)
                if tool then applySkin(tool) end
            end
        end,
    })
end

Rayfield:Notify({
   Title = "Riel Hub Active",
   Content = "Theme loaded. Ready for skin swaps.",
   Duration = 5,
   Image = 4483362458,
})
