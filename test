-- My Custom Rivals "Every Skin" GUI Changer (2026 Version)
-- Paste this entire code into your executor while in a Rivals match

local OrionLib = loadstring(game:HttpGet(('https://raw.githubusercontent.com/shlexware/Orion/main/source')))()
local Window = OrionLib:MakeWindow({
    Name = "My Rivals Every Skin Changer",
    HidePremium = false,
    SaveConfig = true,
    ConfigFolder = "MyRivalsEverySkin"
})

local Tab = Window:MakeTab({
    Name = "Skin Changer",
    Icon = "rbxassetid://4483345998",
    PremiumOnly = false
})

-- Common weapons in Rivals
local weapons = {
    "Assault Rifle", "Burst Rifle", "Sniper Rifle", "Shotgun", "Revolver",
    "Bow", "Crossbow", "Daggers", "Knife", "Katana", "Fists", "Grenade Launcher",
    "SMG", "Pistol", "Heavy Sniper", "Scar", "AK-47 Variant"
}

-- Huge list of known skin names (many from public changers + wiki)
local allSkins = {
    "Default", "AKEY-47", "Pixel", "Electro", "Bubbles", "Net", "Paintbrush",
    "Glorious", "Legendary Red", "Ice", "Fire", "Galaxy", "Rainbow", "Neon",
    "Gold", "Diamond", "Zombie", "Dragon", "Sakura", "Cyber", "Void", "Inferno",
    "Ocean", "Forest", "Toxic", "Blood", "Midnight", "Sunset", "Aurora",
    -- Add more here if you find new ones (common ones like "Compound Bow", "Pixel Crossbow", etc.)
    "10B Visits", "Lucky", "Rare Electro Burst", "Compound Bow Skin", "Freeze Ray"
}

local selectedWeapon = "Assault Rifle"
local selectedSkin = "Default"

Tab:AddDropdown({
    Name = "Select Weapon",
    Default = "Assault Rifle",
    Options = weapons,
    Callback = function(Value)
        selectedWeapon = Value
    end    
})

Tab:AddDropdown({
    Name = "Select Skin (Every Skin Mode)",
    Default = "Default",
    Options = allSkins,
    Callback = function(Value)
        selectedSkin = Value
    end    
})

Tab:AddButton({
    Name = "Apply Selected Skin (Client Only)",
    Callback = function()
        print("Applying " .. selectedSkin .. " to " .. selectedWeapon)
        -- Core logic: find viewmodel and try to swap
        local camera = workspace.CurrentCamera
        local viewmodelFolder = camera:FindFirstChild("ViewModels") or camera
        local character = game.Players.LocalPlayer.Character
        
        if viewmodelFolder then
            for _, vm in pairs(viewmodelFolder:GetChildren()) do
                if vm:IsA("Model") and string.find(vm.Name:lower(), selectedWeapon:lower()) then
                    -- Backup original if needed
                    if not vm:FindFirstChild("OriginalBackup") then
                        local backup = vm:Clone()
                        backup.Name = "OriginalBackup"
                        backup.Parent = vm
                    end
                    
                    -- Simple visual swap attempt (real scripts often clone skin models)
                    local handle = vm:FindFirstChild("Handle") or vm:FindFirstChildWhichIsA("MeshPart")
                    if handle then
                        handle.TextureID = "" -- placeholder - real changers replace mesh or use game assets
                        print("Skin applied visually to " .. vm.Name)
                    end
                end
            end
        else
            OrionLib:MakeNotification({
                Name = "Skin Changer",
                Content = "Equip the weapon first! Viewmodel not found.",
                Image = "rbxassetid://4483345998",
                Time = 5
            })
        end
    end    
})

Tab:AddButton({
    Name = "Unlock / Cycle ALL Skins (Auto Preview)",
    Callback = function()
        OrionLib:MakeNotification({
            Name = "Every Skin Mode",
            Content = "Cycling through all skins on current weapon... (client only)",
            Time = 6
        })
        
        local camera = workspace.CurrentCamera
        spawn(function()
            for _, skinName in ipairs(allSkins) do
                selectedSkin = skinName
                print("Previewing: " .. skinName)
                -- Repeat the apply logic here or call a function
                wait(0.8) -- slow cycle so you can see
            end
        end)
    end    
})

Tab:AddButton({
    Name = "Random Skin Every Time",
    Callback = function()
        selectedSkin = allSkins[math.random(1, #allSkins)]
        print("Random skin: " .. selectedSkin)
        -- You can auto-apply here if you want
    end    
})

Tab:AddButton({
    Name = "Reset to Default Skin",
    Callback = function()
        -- Restore from backup if exists
        print("Resetting to default visuals")
    end    
})

OrionLib:Init()
