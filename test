-- IMPROVED ROBUST REQUIRE
-- ═══════════════════════════════════════════════
local function robust_require(module)
    local mName = tostring(module):gsub("^.+%.", "")
    if shared[mName] or _G[mName] then return shared[mName] or _G[mName] end
    if getrenv then
        local renv = getrenv()
        if renv._G[mName] or renv.shared[mName] then return renv._G[mName] or renv.shared[mName] end
    end

    local setidentity = setthreadidentity or set_thread_identity or (syn and syn.set_thread_identity) or (fluxus and fluxus.set_thread_identity) or (getgenv and getgenv().set_thread_identity)
    local getidentity = getthreadidentity or get_thread_identity or (syn and syn.get_thread_identity) or (fluxus and fluxus.get_thread_identity) or (getgenv and getgenv().get_thread_identity)

    local old_identity
    if getidentity and setidentity then
        pcall(function() old_identity = getidentity() end)
        pcall(function() setidentity(2) end)
    end

    local success, result = pcall(require, module)
    if not success and getgenv and getgenv().require then
        success, result = pcall(getgenv().require, module)
    end
    if not success then
        success, result = pcall(function() return require(module) end)
    end

    if setidentity and old_identity then pcall(function() setidentity(old_identity) end) end

    if success and result then return result end

    -- Memory scan fallback
    local scan_funcs = {getgc, getregistry, debug.getregistry}
    local getupvalues = debug.getupvalues or getupvalues or getupvalue

    for _, scan in ipairs(scan_funcs) do
        if typeof(scan) == "function" then
            local ok, objs = pcall(scan, true)
            if ok and typeof(objs) == "table" then
                for _, v in pairs(objs) do
                    if typeof(v) == "table" then
                        if mName:find("CosmeticLibrary") and (v.Cosmetics or v.Equip) then return v end
                        if mName:find("ItemLibrary") and v.ViewModels then return v end
                        if mName:find("ClientViewModel") and (v.new or v.GetWrap) then return v end
                        if mName:find("ReplicatedClass") and typeof(v.ToEnum) == "function" then return v end
                    end
                end
            end
        end
    end

    if getupvalues then
        for _, f in pairs(getgc(false)) do
            if typeof(f) == "function" then
                local ups = getupvalues(f)
                for _, up in pairs(ups) do
                    if typeof(up) == "table" then
                        if mName:find("CosmeticLibrary") and up.Cosmetics and up.Equip then return up end
                        if mName:find("ItemLibrary") and up.ViewModels then return up end
                    end
                end
            end
        end
    end

    warn("[!] Failed to load module: " .. mName)
    return nil
end

