-- Sound Object (in Workspace for better audio)
local musicSound = Instance.new("Sound")
musicSound.Name = "UniversalMusic"
musicSound.Volume = 0.7
musicSound.Looped = false
musicSound.Parent = workspace

local isLooping = false
local currentVolume = 0.7

-- Functions
playBtn.MouseButton1Click:Connect(function()
    local id = tonumber(idBox.Text)
    if not id then
        status.Text = "❌ Invalid Audio ID!"
        return
    end
    
    musicSound.SoundId = "rbxassetid://" .. id
    musicSound:Stop()
    musicSound.Looped = isLooping
    musicSound.Volume = currentVolume
    musicSound:Play()
    
    status.Text = "▶ Playing ID: " .. id
end)

pauseBtn.MouseButton1Click:Connect(function()
    if musicSound.IsPlaying then
        musicSound:Pause()
        status.Text = "⏸ Paused"
    else
        musicSound:Resume()
        status.Text = "▶ Resumed"
    end
end)

stopBtn.MouseButton1Click:Connect(function()
    musicSound:Stop()
    status.Text = "■ Stopped"
end)

loopToggle.MouseButton1Click:Connect(function()
    isLooping = not isLooping
    musicSound.Looped = isLooping
    loopToggle.Text = isLooping and "🔁 Loop: ON" or "🔁 Loop: OFF"
end)

-- Simple volume drag (click and drag on slider)
volumeSlider.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        local conn
        conn = game:GetService("UserInputService").InputChanged:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseMovement then
                local mousePos = inp.Position.X
                local sliderPos = volumeSlider.AbsolutePosition.X
                local sliderWidth = volumeSlider.AbsoluteSize.X
                
                local percent = math.clamp((mousePos - sliderPos) / sliderWidth, 0, 1)
                volumeFill.Size = UDim2.new(percent, 0, 1, 0)
                currentVolume = percent
                musicSound.Volume = currentVolume
                volumeLabel.Text = "Volume: " .. math.floor(currentVolume * 100) .. "%"
            end
        end)
        
        game:GetService("UserInputService").InputEnded:Connect(function()
            conn:Disconnect()
        end)
    end
end)

