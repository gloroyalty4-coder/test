-- MODULE LOADING
-- ═══════════════════════════════════════════════
task.spawn(function()
    task.wait(3)

    -- Stronger search for modules (post-Reloaded)
    local Modules = ReplicatedStorage:FindFirstChild("Modules") or ReplicatedStorage:WaitForChild("Modules", 10)

    CosmeticLibrary = nil
    for _, v in ipairs(Modules:GetDescendants()) do
        if v.Name == "CosmeticLibrary" then
            local ok, lib = pcall(require, v)
            if ok and lib then CosmeticLibrary = lib; break end
        end
    end

    ItemLibrary = nil
    for _, v in ipairs(Modules:GetDescendants()) do
        if v.Name == "ItemLibrary" then
            local ok, lib = pcall(require, v)
            if ok and lib then ItemLibrary = lib; break end
        end
    end

    ReplicatedClass = nil
    for _, v in ipairs(Modules:GetDescendants()) do
        if v.Name == "ReplicatedClass" then
            local ok, lib = pcall(require, v)
            if ok and lib then ReplicatedClass = lib; break end
        end
    end

    -- ClientViewModel
    ClientViewModel = nil
    local clientModules = player.PlayerScripts:FindFirstChild("Modules")
    if clientModules then
        for _, v in ipairs(clientModules:GetDescendants()) do
            if v.Name == "ClientViewModel" then
                local ok, lib = pcall(require, v)
                if ok and lib then ClientViewModel = lib; break end
            end
        end
    end

    if not CosmeticLibrary or not ReplicatedClass or not ClientViewModel then
        Status.Text = "❌ Failed to load modules - Arsenal updated?"
        warn("Module status:", {
            Cosmetic = not not CosmeticLibrary,
            ReplicatedClass = not not ReplicatedClass,
            ClientViewModel = not not ClientViewModel
        })
        return
    end

    Status.Text = "✅ Modules loaded - Applying hooks..."

    -- getCosmeticData + Hooks (paste your original getCosmeticData, GetWrap hook, new hook, ApplyAllSkins here)

    local function getCosmeticData(name, cType)
        local base = CosmeticLibrary.Cosmetics and CosmeticLibrary.Cosmetics[name]
        if not base then return nil end
        local data = table.clone(base)
        data.Name = name
        data.Type = cType
        return data
    end

    -- (Add your GetWrap and new hooks here exactly as before)

    local function ApplyAllSkins()
        for weapon, info in pairs(_G.EquippedData) do
            if info.Skin ~= "Default" then
                pcall(function() CosmeticLibrary.Equip(weapon, "Skin", info.Skin) end)
            end
        end
    end

    ApplyAllSkins()

    Status.Text = "✅ Fully Loaded! Press K to toggle"
    Title.Text = "Aniha Skin Changer  •  [ K ] Toggle"

    print("[+] Aniha Skin Changer v2.4 loaded successfully!")
end)
