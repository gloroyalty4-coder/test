-- ==================== REAL CHAMS (Highlight) ====================
local function createChams(character)
    if highlights[character] then return end
    local highlight = Instance.new("Highlight")
    highlight.Name = "UE_Chams"
    highlight.FillColor = chamsFillColor
    highlight.OutlineColor = chamsOutlineColor
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0
    highlight.Adornee = character
    highlight.Parent = character  -- or LocalPlayer:WaitForChild("PlayerGui")
    highlights[character] = highlight
end

RunService.RenderStepped:Connect(function()
    if not chamsEnabled then return end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            createChams(player.Character)
        end
    end
end)

-- ==================== RAGEBOT WITH AUTO-FIRE ====================
local function getNearestEnemy()
    local closest = nil
    local shortest = math.huge
    local myPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart.Position

    if not myPos then return nil end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild(aimPart) then
            local dist = (plr.Character[aimPart].Position - myPos).Magnitude
            if dist < shortest and dist < 300 then  -- max range limit
                shortest = dist
                closest = plr.Character[aimPart]
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    if not ragebot then return end
    local target = getNearestEnemy()
    if target and LocalPlayer.Character then
        local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
        if tool then
            -- Face target (helps with some guns)
            local hrp = LocalPlayer.Character.HumanoidRootPart
            hrp.CFrame = CFrame.lookAt(hrp.Position, target.Position)

            -- Auto fire simulation
            if tool:FindFirstChild("GunScript") or tool:FindFirstChild("Shoot") then  -- adjust for Rivals gun structure
                mouse1click()  -- left click fire
            end
        end
    end
end)

-- ==================== SILENT AIM + WALLBANG HOOK ====================
local oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()

    if (silentAim or ragebot) and (method == "FireServer" or method == "InvokeServer") then
        local name = self.Name:lower()
        if name:find("bullet") or name:find("shoot") or name:find("hit") or name:find("damage") then
            local target = getNearestEnemy()
            if target then
                local pos = target.Position + (target.Velocity * prediction)
                if wallbang then
                    -- Force through walls (game dependent)
                    args[1] = pos + Vector3.new(0, 0, 0)  -- you can tweak
                else
                    args[1] = pos
                end
            end
        end
    end

    -- Basic Anti-Katana (block stab/damage remotes)
    if antiKatana and (method == "FireServer" or method == "InvokeServer") then
        local name = self.Name:lower()
        if name:find("stab") or name:find("katana") or name:find("knife") or name:find("damage") then
            return  -- block the remote
        end
    end

    return oldNamecall(self, unpack(args))
end)

