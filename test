-- Silent Aim + Wallbang/Magic Bullet (hook fixed)
local oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()

    if (silentAim or ragebot) and (method == "FireServer" or method == "InvokeServer") then
        local name = self.Name:lower()
        if name:find("bullet") or name:find("shoot") or name:find("hit") or name:find("damage") then
            local target = getNearestEnemy()
            if target then
                local pos = target.Position + (target.Velocity * prediction)
                args[1] = pos  -- Fixed: always apply (Wallbang/Magic Bullet now works)
            end
        end
    end

    if antiKatana and (method == "FireServer" or method == "InvokeServer") then
        local name = self.Name:lower()
        if name:find("stab") or name:find("katana") or name:find("knife") or name:find("damage") then
            return -- Block katana damage packets
        end
    end

    return oldNamecall(self, unpack(args))
end)

-- ==================== MOVEMENT (noclip fixed) ====================
-- Fly
RunService.RenderStepped:Connect(function()
    if flyEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        if not bodyVelocity then
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
            bodyVelocity.Parent = hrp
        end
        local cam = workspace.CurrentCamera
        local moveDir = Vector3.new()
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir += cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir -= cam.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir -= cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir += cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then moveDir += Vector3.new(0,1,0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir -= Vector3.new(0,1,0) end
        bodyVelocity.Velocity = (moveDir.Unit or Vector3.new()) * flySpeed
    elseif bodyVelocity then
        bodyVelocity:Destroy()
        bodyVelocity = nil
    end
end)

